{
  "name": "oak-invest",
  "version": "0.1.0",
  "description": "Howard Marks-inspired investment analysis CLI agent",
  "type": "module",
  "bin": {
    "oak-invest": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "investment",
    "howard-marks",
    "oak-tree",
    "value-investing",
    "cycle-analysis",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.67.68",
    "@mariozechner/pi-ai": "^0.67.68",
    "@mariozechner/pi-tui": "^0.67.68",
    "@sinclair/typebox": "^0.34.49",
    "chalk": "^5.4.0",
    "cheerio": "^1.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "p-limit": "^7.3.0",
    "yahoo-finance2": "^3.14.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
